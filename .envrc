# direnv loads variables from .env.local into the shell environment whenever
# you `cd` into this directory. Required so that ${env:VAR} references in
# .mcp.json resolve correctly for project-scoped MCP servers (notably the
# GITHUB_PERSONAL_ACCESS_TOKEN).
#
# First-time setup on a fresh machine:
#   1) brew install direnv
#   2) Add `eval "$(direnv hook zsh)"` to ~/.zshrc
#   3) Reload your shell (`exec zsh`) and `cd` here
#   4) direnv allow
#
# See docs/setup/mcp-servers.md for full MCP setup details.

dotenv .env.local
