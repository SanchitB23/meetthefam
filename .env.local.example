# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# ─── Supabase ──────────────────────────────────────────────────────────
# For local dev: these come from `supabase start` output.
# For QA / Prod: from Supabase project dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — used by /share/[token] route to bypass RLS.
# NEVER expose this to the client.
SUPABASE_SERVICE_ROLE_KEY=

# ─── MCP server tokens (project scope, used by .mcp.json) ──────────────
# Referenced from .mcp.json via ${env:VAR_NAME}. Loaded into the shell
# environment by direnv (see .envrc) on `cd`.

# Supabase personal access token (https://supabase.com/dashboard/account/tokens)
SUPABASE_ACCESS_TOKEN=

# Note: GitHub MCP and Vercel MCP both run at user scope (literal tokens
# in ~/.claude/settings.json, not here). See docs/setup/mcp-servers.md.

# ─── Status page ───────────────────────────────────────────────────────
# Public URL of the hosted BetterStack status page. When set, the landing
# footer renders a "Status" link; when unset, no link renders (so no dead
# link ships before the page is live). Set in Vercel before v1.0 launch.
# See docs/dev/prod-readiness.md §10. Example: https://meetthefam.betteruptime.com
NEXT_PUBLIC_STATUS_URL=

# ─── QA smoke runner ───────────────────────────────────────────────────
# Vercel protection-bypass-for-automation secret.
# Set in Vercel project: Settings > Deployment Protection > Protection Bypass for Automation.
# Used by the e2e-smoke-tester agent (docs/qa/smoke-flows.md) when driving Playwright
# against SSO-protected preview deployments.
VERCEL_PROTECTION_BYPASS=
