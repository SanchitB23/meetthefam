# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# ─── Supabase ──────────────────────────────────────────────────────────
# For local dev: these come from `supabase start` output.
# For QA / Prod: from Supabase project dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — used by /share/[token] route to bypass RLS.
# NEVER expose this to the client.
SUPABASE_SERVICE_ROLE_KEY=

# ─── MCP server tokens ─────────────────────────────────────────────────
# Referenced from .mcp.json via ${env:VAR_NAME} so the .mcp.json file
# itself stays committable.

# Supabase personal access token (https://supabase.com/dashboard/account/tokens)
SUPABASE_ACCESS_TOKEN=

# GitHub fine-grained personal access token with repo scope on this repo
GITHUB_PERSONAL_ACCESS_TOKEN=

# Vercel access token (https://vercel.com/account/tokens)
VERCEL_ACCESS_TOKEN=
