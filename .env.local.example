# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# ─── Supabase ──────────────────────────────────────────────────────────
# For local dev: these come from `supabase start` output.
# For QA / Prod: from Supabase project dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — used by /share/[token] route to bypass RLS.
# NEVER expose this to the client.
SUPABASE_SERVICE_ROLE_KEY=

# ─── MCP server tokens (project scope, used by .mcp.json) ──────────────
# Referenced from .mcp.json via ${env:VAR_NAME}. Loaded into the shell
# environment by direnv (see .envrc) on `cd`.

# Supabase personal access token (https://supabase.com/dashboard/account/tokens)
SUPABASE_ACCESS_TOKEN=

# Note: GitHub MCP and Vercel MCP both run at user scope (literal tokens
# in ~/.claude/settings.json, not here). See docs/setup/mcp-servers.md.

# ─── Site URL (sitemap / robots / absolute URLs) ───────────────────────
# Canonical production origin — no trailing slash.
# Falls back to VERCEL_PROJECT_PRODUCTION_URL (auto-injected by Vercel) then
# http://localhost:3000. Set this in Vercel before v1.0 launch so sitemap +
# og-image absolute URLs use the real domain. Example: https://meetthefam.app
NEXT_PUBLIC_SITE_URL=

# ─── Status page ───────────────────────────────────────────────────────
# Public URL of the hosted BetterStack status page. When set, the landing
# footer renders a "Status" link; when unset, no link renders (so no dead
# link ships before the page is live). Set in Vercel before v1.0 launch.
# See docs/dev/prod-readiness.md §10. Example: https://meetthefam.betteruptime.com
NEXT_PUBLIC_STATUS_URL=

# ─── QA smoke runner ───────────────────────────────────────────────────
# Vercel protection-bypass-for-automation secret.
# Set in Vercel project: Settings > Deployment Protection > Protection Bypass for Automation.
# Used by the e2e-smoke-tester agent (docs/qa/smoke-flows.md) when driving Playwright
# against SSO-protected preview deployments.
VERCEL_PROTECTION_BYPASS=

# ─── Email delivery (Resend) ───────────────────────────────────────────
# Custom SMTP / invite delivery. See docs/superpowers/specs/2026-05-30-custom-smtp-design.md.
#
# AUTH emails (magic-link, confirm-signup) do NOT use these vars — they are
# configured in the Supabase Dashboard (Auth → SMTP Settings) for QA/prod,
# and caught by Mailpit (:54324) locally. These vars only drive the
# collaboration-invite send path in src/lib/email/inviteEmail.ts.
#
# Server-only — NEVER prefix with NEXT_PUBLIC_.
# Resend API key (https://resend.com → API Keys). Leave blank locally unless
# you are explicitly testing invite delivery with the flag flipped on.
RESEND_API_KEY=
# Verified sender address (Resend → Domains) — same value across all envs:
RESEND_FROM_EMAIL=noreply-mtf@sanchitb23.in
# Set to "true" to actually send invite emails. Unset/anything-else = the
# invite path is a console.log no-op (the default for local dev).
MEETTHEFAM_EMAIL_INVITES_ENABLED=

# ─── Export flags ──────────────────────────────────────────────────────
# Set to "false" to revert PNG export to the legacy toBlob path (#219). Unset/any other value = canvas path.
# NEXT_PUBLIC_EXPORT_PNG_VIA_CANVAS=false
