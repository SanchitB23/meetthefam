{
  "$schema": "https://design-tokens.org/schema.json",
  "_meta": {
    "name": "meetTheFam design tokens",
    "version": "1.0.0",
    "note": "Drop into Tailwind v4 @theme, CSS vars, or Style Dictionary. See theme.css for ready-made @theme block."
  },
  "color": {
    "brand": {
      "ink":    { "value": "#2D4A3E", "oklch": "oklch(33.5% 0.04 158)", "note": "Primary forest green — primary buttons, body text" },
      "accent": { "value": "#C77B5C", "oklch": "oklch(64% 0.10 39)",   "note": "Terracotta — destructive/promote calls, CTA accents" },
      "cream":  { "value": "#F5EFE3", "oklch": "oklch(95% 0.015 80)",  "note": "App background — never pure white" },
      "paper":  { "value": "#FFFCF5", "oklch": "oklch(98.7% 0.01 85)", "note": "Card / elevated surfaces" },
      "mid":    { "value": "#6B6358", "oklch": "oklch(46% 0.015 70)",  "note": "Secondary text, hairline borders" }
    },
    "tone": {
      "sage":   { "bg": "#E4ECDD", "ring": "#A9BC92", "ink": "#3D5340" },
      "rose":   { "bg": "#F1DAD0", "ring": "#D49A85", "ink": "#7A3F2C" },
      "indigo": { "bg": "#DDE0EC", "ring": "#8E96B8", "ink": "#3B4068" },
      "amber":  { "bg": "#F2E3C5", "ring": "#C9A86A", "ink": "#6E5224" },
      "green":  { "bg": "#CFE0CD", "ring": "#7DA078", "ink": "#2D4A3E" }
    },
    "dark": {
      "ink":    "#E8DFD0",
      "accent": "#E09376",
      "cream":  "#1B1814",
      "paper":  "#241F18",
      "mid":    "#9A9081",
      "_note":  "Warm-shifted dark-mode pairs. Map to .dark class tokens directly."
    }
  },
  "radius": {
    "xs":   "6px",
    "sm":   "10px",
    "md":   "14px",
    "lg":   "20px",
    "xl":   "24px",
    "pill": "999px"
  },
  "shadow": {
    "card":     "0 1px 2px rgba(60,40,20,.03), 0 8px 28px rgba(60,40,20,.05)",
    "node":     "0 1px 2px rgba(60,40,20,.04), 0 4px 12px rgba(60,40,20,.05)",
    "node-hover":"0 0 0 3px rgba(45,74,62,.12), 0 8px 24px rgba(60,40,20,.10)",
    "panel":    "-12px 0 40px rgba(60,40,20,.08)",
    "fab":      "0 8px 22px rgba(199,123,92,.45)"
  },
  "spacing": {
    "0": "0", "1": "4px", "2": "8px", "3": "12px", "4": "16px",
    "5": "20px", "6": "24px", "8": "32px", "10": "40px", "12": "48px"
  },
  "type": {
    "family": {
      "display": "\"Cormorant Garamond\", Georgia, serif",
      "body":    "\"Manrope\", system-ui, sans-serif"
    },
    "weight":  { "regular": 400, "medium": 500, "semibold": 600, "bold": 700 },
    "size":    {
      "xs":   "11px",  "sm":   "12.5px", "base": "14px",
      "lg":   "16px",  "xl":   "20px",   "2xl":  "28px",
      "3xl":  "34px",  "4xl":  "44px",   "5xl":  "64px"
    },
    "italicMin": "16px (Cormorant italic illegible below this — WCAG soft floor)"
  },
  "a11y": {
    "contrast": {
      "ink_on_cream":   "8.9:1  (AAA · pass)",
      "ink_on_paper":   "9.6:1  (AAA · pass)",
      "mid_on_cream":   "4.7:1  (AA  · body pass, large pass)",
      "accent_on_cream":"3.4:1  (AA large only — never use for body text)",
      "paper_on_ink":   "9.6:1  (AAA · pass — primary buttons)"
    },
    "italicMinSize": 16,
    "tapTargetMin":  44
  }
}
